# Server Ports
PORT=5000

# Client Application URL
CLIENT_URL=http://localhost:5173

# PostgreSQL Database Connection (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hms_db?schema=public"

# MongoDB Database Connection (Mongoose)
MONGODB_URI="mongodb://localhost:27017/hms_clinical"

# Cryptography & Security Secrets (Ensure ENCRYPTION_SECRET is exactly 32 bytes or sha256'ed)
ENCRYPTION_SECRET="supersecret_healthcare_encryption_passphrase_key"
JWT_ACCESS_SECRET="hms_access_token_jwt_secret_key_2026_extremely_secure"
JWT_REFRESH_SECRET="hms_refresh_token_jwt_secret_key_2026_extremely_secure"

# OpenAI API (Optional - local fallback runs if missing)
OPENAI_API_KEY="sk-proj-..."
